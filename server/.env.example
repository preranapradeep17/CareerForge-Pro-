PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/careerforge-pro
JWT_SECRET=replace-with-a-strong-secret

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Dashboard → Developers → API Keys (use sk_test_... for dev, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook secret — copy from: stripe listen --forward-to localhost:5000/api/payments/webhook
# Or from Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Create a Product + Price in Stripe Dashboard → Products → Add Product
# Set it to $12/mo recurring → copy the Price ID (starts with price_)
STRIPE_PRO_PRICE_ID=price_your_monthly_pro_price_id

# Fallback used only when STRIPE_PRO_PRICE_ID is not set (creates ad-hoc inline price)
STRIPE_PRO_AMOUNT_CENTS=1200
STRIPE_PRO_CURRENCY=usd
STRIPE_PRO_INTERVAL=month

# ─── Client URL ──────────────────────────────────────────────────────────────
# Vite dev default. Change to your deployed domain in production.
CLIENT_URL=http://localhost:5173
